{
  "name": "@northern.tech/testing",
  "version": "0.14.0",
  "license": "Apache-2.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NorthernTechHQ/nt-gui.git"
  },
  "exports": {
    "./baseTestConfig.json": "./dist/public/baseTestConfig.json",
    "./**/*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.cjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.cjs"
    }
  },
  "files": [
    "dist",
    "dist/public/baseTestConfig.json"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --onSuccess 'yalc publish --no-script --push'",
    "lint": "eslint --quiet .",
    "format:check": "prettier --check \"src/**/*.{js,ts,jsx,tsx,less}\""
  },
  "type": "module",
  "sideEffects": false,
  "devDependencies": {
    "@northern.tech/eslint-config": "*",
    "@northern.tech/typescript-config": "*",
    "eslint": "^9.39.1",
    "tsdown": "^0.22.2"
  },
  "dependencies": {
    "js-yaml": "^5.1.0",
    "openapi-backend": "^5.x"
  },
  "peerDependencies": {
    "@emotion/jest": "^11.x",
    "@mui/material": "^9.1.2",
    "@northern.tech/utils": "*",
    "@reduxjs/toolkit": "^2.x",
    "@testing-library/react": "^16.x",
    "msw": "^2.x",
    "react": "19.x",
    "react-redux": "^9.x",
    "react-router": "^8.x",
    "vitest": "^4.x"
  }
}
